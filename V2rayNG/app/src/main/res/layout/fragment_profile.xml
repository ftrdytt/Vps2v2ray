<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0C">

    <androidx.appcompat.widget.Toolbar
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#141417"
        app:title="الملف الشخصي"
        app:titleTextColor="#FFFFFF"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/btn_admin_dashboard"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="20dp"
                    android:background="@drawable/ic_circle"
                    android:backgroundTint="#252529"
                    android:padding="12dp"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    app:tint="#FF9800"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/btn_update_logs"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="20dp"
                    android:background="@drawable/ic_circle"
                    android:backgroundTint="#252529"
                    android:padding="12dp"
                    android:src="@android:drawable/ic_menu_recent_history"
                    app:tint="#4CAF50"
                    android:visibility="gone" />

                <FrameLayout
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_gravity="center">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/ic_circle"
                        android:backgroundTint="#FF9800"
                        android:alpha="0.2"/>

                    <androidx.cardview.widget.CardView
                        android:layout_width="128dp"
                        android:layout_height="128dp"
                        android:layout_gravity="center"
                        app:cardCornerRadius="64dp"
                        app:cardBackgroundColor="#1A1A1D"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/iv_profile_pic"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_stat_name"
                            app:tint="#80FFFFFF"/>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="8dp"
                        app:cardCornerRadius="18dp"
                        app:cardBackgroundColor="#FF9800">
                        <ImageView
                            android:id="@+id/btn_change_avatar"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_camera"
                            app:tint="#FFFFFF"/>
                    </androidx.cardview.widget.CardView>
                </FrameLayout>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="اضغط على الصورة لتغييرها"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:layout_marginBottom="32dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="#1A1A1D"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxStrokeWidth="0dp"
                android:layout_marginBottom="16dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_profile_id"
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:hint="الايدي الخاص بك (ID)"
                    android:textColorHint="#80FFFFFF"
                    android:textColor="#FF9800"
                    android:enabled="false"
                    android:textStyle="bold"
                    android:textSize="18sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="#1A1A1D"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxStrokeWidth="0dp"
                android:layout_marginBottom="16dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_profile_name"
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:hint="اسم المستخدم"
                    android:textColorHint="#80FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundColor="#1A1A1D"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxStrokeWidth="0dp"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="#80FFFFFF"
                app:hintTextColor="#80FFFFFF"
                android:layout_marginBottom="32dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_profile_pass"
                    android:layout_width="match_parent"
                    android:layout_height="65dp"
                    android:hint="كلمة المرور"
                    android:textColorHint="#80FFFFFF"
                    android:inputType="textPassword"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_profile"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:text="حفظ التعديلات السحابية"
                android:textSize="18sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:backgroundTint="#4CAF50"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:text="تسجيل خروج آمن"
                android:textColor="#FF5252"
                android:textSize="16sp"
                app:strokeColor="#FF5252"
                app:strokeWidth="1dp"
                app:cornerRadius="16dp"
                app:backgroundTint="#0A0A0C"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
