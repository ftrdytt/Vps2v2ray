<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0C">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="لوحة تحكم الإدارة"
        android:textColor="#FF9800"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="20dp"
        android:background="#1A1A1D"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:background="#141417">

        <Button
            android:id="@+id/tab_all_users"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="جميع المستخدمين"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF9800"
            android:textSize="12sp"/>

        <Button
            android:id="@+id/tab_active_now"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="النشطين الآن"
            android:textColor="#80FFFFFF"
            android:backgroundTint="#252529"
            android:textSize="12sp"
            android:layout_marginHorizontal="5dp"/>

        <Button
            android:id="@+id/tab_stats"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="الإحصائيات"
            android:textColor="#80FFFFFF"
            android:backgroundTint="#252529"
            android:textSize="12sp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_all_users_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="visible">

        <TextView
            android:id="@+id/tv_total_users"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="إجمالي المستخدمين: جاري التحميل..."
            android:textColor="#4CAF50"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="10dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:id="@+id/list_all_users"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp"/>
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_active_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        android:gravity="center">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="قسم النشطين سيتم تفعيله في المرحلة القادمة" android:textColor="#80FFFFFF" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_stats_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        android:gravity="center">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="قسم الإحصائيات سيتم تفعيله في المرحلة القادمة" android:textColor="#80FFFFFF" />
    </LinearLayout>

</LinearLayout>
