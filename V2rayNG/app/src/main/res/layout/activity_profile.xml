<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0C">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#141417"
        app:title="الملف الشخصي"
        app:titleTextColor="#FFFFFF"
        app:navigationIcon="?attr/homeAsUpIndicator"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <androidx.cardview.widget.CardView
                android:layout_width="120dp"
                android:layout_height="120dp"
                app:cardCornerRadius="60dp"
                app:cardBackgroundColor="#1A1A1D"
                android:layout_marginBottom="16dp">
                <ImageView
                    android:id="@+id/iv_profile_pic"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="#80FFFFFF"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="تغيير الصورة الشخصية"
                android:textColor="#2196F3"
                android:textSize="14sp"
                android:id="@+id/tv_change_pic"
                android:layout_marginBottom="32dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الايدي الخاص بك (ID)"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>
                <EditText
                    android:id="@+id/et_profile_id"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/ic_circle"
                    android:backgroundTint="#1A1A1D"
                    android:textColor="#FF9800"
                    android:paddingHorizontal="16dp"
                    android:enabled="false"
                    android:textStyle="bold"
                    android:textSize="18sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الاسم"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>
                <EditText
                    android:id="@+id/et_profile_name"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/ic_circle"
                    android:backgroundTint="#1A1A1D"
                    android:textColor="#FFFFFF"
                    android:paddingHorizontal="16dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="32dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="كلمة المرور"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>
                <EditText
                    android:id="@+id/et_profile_pass"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/ic_circle"
                    android:backgroundTint="#1A1A1D"
                    android:textColor="#FFFFFF"
                    android:paddingHorizontal="16dp"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_profile"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="حفظ التعديلات"
                android:textSize="16sp"
                app:cornerRadius="12dp"
                app:backgroundTint="#4CAF50"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="تسجيل خروج"
                android:textSize="16sp"
                app:cornerRadius="12dp"
                app:backgroundTint="#D32F2F"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
