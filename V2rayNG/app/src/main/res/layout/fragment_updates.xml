<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipe_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0C">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="مركز التحديثات"
                android:textColor="#FF9800"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <LinearLayout
                android:id="@+id/layout_admin_upload"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:background="@drawable/ic_circle"
                android:backgroundTint="#1A1A1D"
                android:padding="16dp"
                android:layout_marginBottom="24dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="رفع تحديث جديد للمستخدمين"
                    android:textColor="#4CAF50"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <EditText
                    android:id="@+id/et_version_code"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="رقم الإصدار الجديد (مثال: 4000710)"
                    android:inputType="number"
                    android:textColorHint="#80FFFFFF"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/ic_circle"
                    android:backgroundTint="#0A0A0C"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="16dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_upload_apk"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="اختر ملف الـ APK وارفعه للسيرفر"
                    app:cornerRadius="12dp"
                    app:backgroundTint="#2196F3"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="إدارة التحديثات السابقة:"
                    android:textColor="#FF9800"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>
                
                <LinearLayout
                    android:id="@+id/layout_admin_history"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="24dp">
                
                <TextView
                    android:id="@+id/tv_progress_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="جاري معالجة التطبيق..."
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="8dp"/>
                    
                <ProgressBar
                    android:id="@+id/pb_download_upload"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="20dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#FF9800"/>
                    
                <TextView
                    android:id="@+id/tv_progress_percent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#FF9800"
                    android:gravity="end"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_current_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="إصدار التطبيق الحالي: "
                android:textColor="#80FFFFFF"
                android:textSize="14sp"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp"/>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
